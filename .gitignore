target/
node_modules/
dist/
coverage/
*.log
.DS_Store
pnpm-lock.yaml

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
build/
.pytest_cache/
.coverage
.coverage.*

# Dolt database files (added by bd init)
.dolt/
*.db

# Beads issue tracker (local only)
.beads/
docs/.vitepress/cache
docs/.vitepress/dist
docs/node_modules/

# cargo-llvm-cov regenerates these for the unit-coverage Rust fixture crates
packages/rust/tests/fixtures/unit_coverage/rust/*/Cargo.lock
.github/selftest/coverage-rust/**/Cargo.lock
.github/selftest/integration-rust/**/Cargo.lock

# cargo-mutants output + lockfiles regenerated for the unit-mutation fixture crates
mutants.out/
packages/rust/tests/fixtures/unit_mutation/rust/*/Cargo.lock
.github/selftest/mutation/*/Cargo.lock

# Stryker run artifacts for the TypeScript unit-mutation fixtures (cleaned up after a
# run; ignored so an interrupted run never leaks them into git)
packages/rust/tests/fixtures/unit_mutation/typescript/*/reports/
packages/rust/tests/fixtures/unit_mutation/typescript/*/.stryker-tmp/
.stryker-tmp/
