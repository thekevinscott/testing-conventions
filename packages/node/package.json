{
  "name": "testing-conventions",
  "version": "0.0.1",
  "description": "Enforce testing conventions in libraries (Python, TypeScript, and Rust).",
  "license": "MIT",
  "repository": "https://github.com/thekevinscott/testing-conventions",
  "type": "module",
  "bin": {
    "testing-conventions": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/vitest-config.d.ts",
      "import": "./dist/vitest-config.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "pnpm run build && cargo build --release --manifest-path ../rust/Cargo.toml --bin testing-conventions && vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.20.0"
  },
  "dependencies": {
    "bin-shim": "^0.1.1",
    "@stryker-mutator/core": "^8.7.0",
    "@stryker-mutator/vitest-runner": "^8.7.0"
  },
  "peerDependencies": {
    "vitest": ">=2"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@testing-conventions/x86_64-unknown-linux-gnu": "0.0.1",
    "@testing-conventions/aarch64-unknown-linux-gnu": "0.0.1",
    "@testing-conventions/x86_64-apple-darwin": "0.0.1",
    "@testing-conventions/aarch64-apple-darwin": "0.0.1",
    "@testing-conventions/x86_64-pc-windows-msvc": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
